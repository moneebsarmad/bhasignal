# Root environment
NODE_ENV=development

# Web app
NEXT_PUBLIC_APP_NAME=Signal
AUTH_SESSION_SECRET=replace-with-a-long-random-secret-min-32-chars
AUTH_ADMIN_EMAIL=admin@school.org
AUTH_ADMIN_PASSWORD=change-me
AUTH_REVIEWER_EMAIL=reviewer@school.org
AUTH_REVIEWER_PASSWORD=change-me
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_URL=
CRON_SECRET=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
INGESTION_MAX_UPLOAD_BYTES=15728640
INGESTION_MAX_UPLOAD_PAGES=150
PARSER_MAX_ATTEMPTS=3
PARSER_RETRY_BASE_MS=500
SHEETS_API_MAX_ATTEMPTS=6
SHEETS_API_RETRY_BASE_MS=500
SHEETS_TAB_CACHE_TTL_MS=5000
SYCAMORE_API_ENABLED=true
SYCAMORE_ACCESS_TOKEN=
# Legacy alias still supported:
# SYCAMORE_API_ACCESS_TOKEN=
SYCAMORE_SCHOOL_ID=
SYCAMORE_API_BASE_URL=https://app.sycamoreschool.com/api/v1
SYCAMORE_DISCIPLINE_PATH_TEMPLATE=/School/{schoolId}/Discipline
SYCAMORE_STUDENTS_PATH_TEMPLATE=/School/{schoolId}/Students
SYCAMORE_API_TIMEOUT_MS=15000
SYCAMORE_API_MAX_ATTEMPTS=3
SYCAMORE_API_RETRY_BASE_MS=500
SYCAMORE_REQUEST_DELAY_MS=150
SYCAMORE_SCHOOL_YEAR_START_MONTH=8
SYCAMORE_SCHOOL_YEAR_START_DAY=1
SYCAMORE_INCREMENTAL_OVERLAP_DAYS=1

# Parser service
PARSER_BASE_URL=http://localhost:8000
